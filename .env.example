# Postgres / Supabase database configuration
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Supabase configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI recommendations
# Set LLM_PROVIDER to 'lmstudio' to use a local LM Studio server (recommended for local dev)
# Set LLM_PROVIDER to 'gemini' to use Google Gemini API
LLM_PROVIDER=lmstudio

# LM Studio (local) — run LM Studio, load a model, and start the server
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=google/gemma-4-e4b
# For remote access via ngrok, replace LMSTUDIO_BASE_URL with your ngrok URL:
# LMSTUDIO_BASE_URL=https://sarcastic-traffic-ankle.ngrok-free.dev/v1

# Gemini (fallback) — used if LLM_PROVIDER=gemini or as fallback when LM Studio is unreachable
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# MCP recommendations (optional)
# Uses the local MCP server at mcp/server.mjs when enabled.
MCP_RECOMMENDATIONS_ENABLED=false
MCP_SERVER_COMMAND=
MCP_SERVER_ARGS=["mcp/server.mjs"]

# NextAuth Azure AD configuration
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# NextAuth defaults
AUTH_URL=http://localhost:3000/api/auth

# LinkedIn OAuth (Sign in with LinkedIn)
# Create an app at https://www.linkedin.com/developers/apps and enable "Sign In with LinkedIn using OpenID Connect"
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# LinkedIn Learning integration
LINKEDIN_LEARNING_CLIENT_ID=
LINKEDIN_LEARNING_CLIENT_SECRET=
LINKEDIN_LEARNING_ORGANIZATION_URN=
LINKEDIN_LEARNING_DEFAULT_LOCALE=en_US
LINKEDIN_LEARNING_API_VERSION=202404
# Set to true to use bundled sample data instead of the real API in development.
LINKEDIN_LEARNING_USE_STUB=true
LINKEDIN_LEARNING_SCOPE="learning openid profile r_liteprofile r_emailaddress organization_learning"

# SIP2 emulator configuration
SIP2_BASE_URL=
SIP2_API_KEY=

# Development testing (optional)
DEV_AZURE_EMAIL_SUFFIX=

